---
interface Props {
  class?: string;
  size?: 'nav' | 'hero';
}

const { class: className = '', size = 'hero' } = Astro.props;

const sizeClasses = size === 'nav'
  ? 'text-lg'
  : 'text-4xl sm:text-5xl md:text-6xl';
---

<span
  class:list={[
    "font-['Silkscreen'] text-accent font-bold tracking-tight inline-block",
    sizeClasses,
    className,
  ]}
  aria-label="Feynman"
>feynman</span>
